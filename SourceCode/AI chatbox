from pymongo import MongoClient
import tkinter as tk

# Connect to MongoDB
client = MongoClient("mongodb://localhost:27017/") 
db = client["Localbite"]
restaurants = db["restaurants"]

print("Restaurant data:", list(restaurants.find())

def send_message():

    user_message = entry.get().lower()

    if user_message.strip() == "":
        return

    chat.insert(tk.END, f"\nYou: {user_message}\n")

  # Greeting
    if "hello" in user_message or "hi" in user_message:
        chat.insert(tk.END, "AI: Hi! I'm the LocalBite assistant. Ask me for food recommendations.\n")

 # Cuisine detection
    cuisines = ["thai", "indian", "italian", "chinese", "american", "cafe"]

    for cuisine in cuisines:
        if cuisine in user_message:

            results = list(
                restaurants.find(
                    {"cuisine": {"$regex": cuisine, "$options": "i"}}
                ).sort("rating", -1).limit(3)
            )

            if results:
                chat.insert(tk.END, f"AI: Here are some great {cuisine.title()} restaurants:\n\n")

                for r in results:
                    chat.insert(tk.END, f"🍽 {r['name']} ⭐ {r['rating']}\n")

            else:
                chat.insert(tk.END, f"AI: I couldn't find any {cuisine} restaurants.\n")

            chat.see(tk.END)
            entry.delete(0, tk.END)
            return



# General recommendation
    elif "recommend" in user_message or "best" in user_message:

        results = restaurants.find().sort("rating",-1).limit(5)

        chat.insert(tk.END, "AI: Here are the highest rated restaurants right now:\n")

        for r in results:
            chat.insert(tk.END, f"🍽 {r['name']} ({r['cuisine']}) ⭐ {r['rating']}\n")

    # Achievements
    elif "achievement" in user_message:

        chat.insert(tk.END, "AI: You can unlock achievements like:\n")
        chat.insert(tk.END, "🏅 Food Explorer – Visit 5 restaurants\n")
        chat.insert(tk.END, "🏅 Master Reviewer – Write 10 reviews\n")
        chat.insert(tk.END, "🏅 Cuisine Expert – Try 3 cuisines\n")

    else:
        chat.insert(tk.END, "AI: I'm not sure I understood. Try asking for restaurant recommendations.\n")

    chat.see(tk.END)
    entry.delete(0, tk.END)

# Window
window = tk.Tk()
window.title("LocalBite AI Chatbot")
window.geometry("600x600")
window.configure(bg="#f4f4f4")


# Header
header = tk.Label(
    window,
    text="🍜 LocalBite AI Assistant",
    font=("Helvetica", 18, "bold"),
    bg="#ff914d",
    fg="white",
    pady=10
)
header.pack(fill=tk.X)


# Chat Frame
chat_frame = tk.Frame(window)
chat_frame.pack(pady=10)

scrollbar = tk.Scrollbar(chat_frame)

chat = tk.Text(
    chat_frame,
    height=25,
    width=70,
    font=("Helvetica", 11),
    yscrollcommand=scrollbar.set,
    wrap="word"
)

scrollbar.config(command=chat.yview)
scrollbar.pack(side=tk.RIGHT, fill=tk.Y)
chat.pack(side=tk.LEFT)


# Input Frame
input_frame = tk.Frame(window, bg="#f4f4f4")
input_frame.pack(pady=10)


entry = tk.Entry(
    input_frame,
    width=40,
    font=("Helvetica", 12)
)
entry.pack(side=tk.LEFT, padx=10)


send_button = tk.Button(
    input_frame,
    text="Send",
    font=("Helvetica", 11),
    bg="#ff914d",
    fg="white",
    command=send_message
)
send_button.pack(side=tk.LEFT)


# Allow Enter key to send messages
window.bind('<Return>', lambda event: send_message())


# Welcome message
chat.insert(tk.END, "AI: Hello! I'm the LocalBite assistant 🍜\n")
chat.insert(tk.END, "AI: Ask me for restaurant recommendations or cuisines!\n\n")


window.mainloop()
